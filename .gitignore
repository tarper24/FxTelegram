# =============================================================================
# FxTelegram .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------

# Superpowers (local planning only, never committed)
.superpowers/

# Cloudflare Workers secrets / local dev vars
.dev.vars
.dev.vars.*

# Wrangler build cache and local state
.wrangler/

# -----------------------------------------------------------------------------
# Node (https://github.com/github/gitignore/blob/main/Node.gitignore)
# -----------------------------------------------------------------------------

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage
*.lcov
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# Snowpack
web_modules/

# TypeScript cache
*.tsbuildinfo

# npm / eslint / stylelint cache
.npm
.eslintcache
.stylelintcache

# REPL history
.node_repl_history

# npm pack output
*.tgz

# Yarn
.yarn-integrity

# Environment variable files
.env
.env.*
!.env.example

# Build caches / output
.cache
.parcel-cache
.next
out
.nuxt
dist
.output
.temp
.svelte-kit/
**/.vitepress/dist
**/.vitepress/cache
.docusaurus

# Serverless
.serverless/

# pnpm
.pnpm-store

# Yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

